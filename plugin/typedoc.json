{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["./src/index.tsx"],
  "out": "docs_raw",
  "plugin": ["typedoc-plugin-markdown"],
  "readme": "../docs/README_BASE.md",
  "disableSources": true,
  "parametersFormat": "table",
  "excludeScopesInPaths": true,
  "hideBreadcrumbs": true,
  "hidePageHeader": true,
  "pageTitleTemplates": {
    "member": "{name}"
  }
}
